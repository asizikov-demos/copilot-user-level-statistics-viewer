{
  "name": "user-level-metrics-viewer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:worker && next dev --turbopack",
    "build": "npm run build:worker -- --production && next build",
    "build:worker": "node scripts/build-worker.mjs",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "anonymize:report": "node --experimental-strip-types data-utils/anonymize-report.ts",
    "update:plugins": "node --experimental-strip-types data-utils/update-plugin-versions.ts"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/ui": "^4.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.2",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "overrides": {
    "flatted": "^3.4.2"
  }
}
